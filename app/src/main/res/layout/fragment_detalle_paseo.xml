<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtDetalleMascota"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paseo de -"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"/>

                <TextView
                    android:id="@+id/txtDetalleFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha: - | Hora: -"
                    android:textSize="14sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/txtDetalleEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDIENTE"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="#E65100"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardMapaDetalle"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardEstado"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.gms.maps.MapView
                android:id="@+id/mapViewDetalle"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPaseador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardMapaDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/lblPaseadorTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🦮 Paseador Asignado"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#334155"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <ImageView
                    android:id="@+id/imgPaseadorFoto"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"
                    app:layout_constraintTop_toBottomOf="@id/lblPaseadorTitulo"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/txtPaseadorNombre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Nombre del Paseador"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    app:layout_constraintTop_toTopOf="@id/imgPaseadorFoto"
                    app:layout_constraintStart_toEndOf="@id/imgPaseadorFoto"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/txtPaseadorCelular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="📞 Celular: -"
                    android:textSize="14sp"
                    android:textColor="#475569"
                    android:layout_marginTop="2dp"
                    app:layout_constraintTop_toBottomOf="@id/txtPaseadorNombre"
                    app:layout_constraintStart_toStartOf="@id/txtPaseadorNombre"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <RatingBar
                    android:id="@+id/rbPaseadorCalificacion"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:rating="0.0"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/txtPaseadorCelular"
                    app:layout_constraintStart_toStartOf="@id/txtPaseadorNombre"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContactarWhatsApp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Contactar por WhatsApp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#25D366"
                    app:icon="@android:drawable/stat_notify_chat"
                    app:iconTint="#FFFFFF"
                    app:cornerRadius="8dp"
                    app:layout_constraintTop_toBottomOf="@id/imgPaseadorFoto"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardDetalles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardPaseador"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Ubicación de Recojo"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#334155"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/txtDetalleDistrito"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Distrito: -"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/txtDetalleDireccion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dirección: -"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:layout_marginBottom="12dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️ Especificaciones Técnicas"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#334155"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/txtDetalleDuracion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Duración: 0 min"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/txtDetalleRadio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Radio de seguridad: 0 metros"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/txtDetallePago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Método de pago: -"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/txtDetalleNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notas: -"
                    android:textSize="15sp"
                    android:textColor="#475569"
                    android:fontStyle="italic"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPrecio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardDetalles"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#334155"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/txtDetallePrecio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/. 0.00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardCalificacionPaseo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardPrecio"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Qué tal le pareció el servicio?"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#334155"
                    android:layout_marginBottom="8dp"/>

                <RatingBar
                    android:id="@+id/rbPaseoEstrellas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1.0"
                    android:rating="0.0"
                    android:isIndicator="false"
                    android:progressTint="#F59E0B"
                    android:secondaryProgressTint="#F59E0B"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEnviarCalificacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Enviar Calificación"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6366F1"
                    app:cornerRadius="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>