<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6.dp"
    app:cardCornerRadius="12.dp"
    app:cardElevation="3.dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14.dp">

        <TextView
            android:id="@+id/txtItemPatita"
            android:layout_width="50.dp"
            android:layout_height="50.dp"
            android:text="🐾"
            android:textSize="36sp"
            android:gravity="center"
            app:layout_constraintBottom_toTopOf="@id/dividerItem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtItemMascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14.dp"
            android:text="Mascota: Firulais"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/txtItemEstado"
            app:layout_constraintStart_toEndOf="@id/txtItemPatita"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtItemFechaHora"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14.dp"
            android:layout_marginTop="4.dp"
            android:text="Fecha 15/05/2026 Hora 16:30"
            android:textColor="@android:color/darker_gray"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/txtItemEstado"
            app:layout_constraintStart_toEndOf="@id/txtItemPatita"
            app:layout_constraintTop_toBottomOf="@id/txtItemMascota" />

        <TextView
            android:id="@+id/txtItemEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FFF3E0"
            android:paddingHorizontal="10.dp"
            android:paddingVertical="4.dp"
            android:text="PENDIENTE"
            android:textColor="#E65100"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/dividerItem"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14.dp"
            android:background="#E0E0E0"
            app:layout_constraintTop_toBottomOf="@id/txtItemFechaHora"
            tools:layout_editor_absoluteX="14.dp" />

        <RatingBar
            android:id="@+id/ratingBarPaseo"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.dp"
            android:numStars="5"
            android:rating="0"
            android:stepSize="1.0"
            android:isIndicator="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dividerItem" />

        <TextView
            android:id="@+id/txtCalificacionInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8.dp"
            android:text="(Calificación pendiente)"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:textStyle="italic"
            app:layout_constraintBottom_toBottomOf="@id/ratingBarPaseo"
            app:layout_constraintStart_toEndOf="@id/ratingBarPaseo"
            app:layout_constraintTop_toTopOf="@id/ratingBarPaseo" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>