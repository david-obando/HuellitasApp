<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16.dp">

        <TextView
            android:id="@+id/lblMascota"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿A quién paseamos hoy?"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Spinner
            android:id="@+id/spinnerMascotas"
            android:layout_width="match_parent"
            android:layout_height="48.dp"
            android:layout_marginTop="6.dp"
            android:background="@android:drawable/btn_dropdown"
            app:layout_constraintTop_toBottomOf="@id/lblMascota" />

        <TextView
            android:id="@+id/lblFechaHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.dp"
            android:text="¿Cuándo pasamos por tu mascota?"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/spinnerMascotas"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layoutFechaHoraInputs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6.dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/lblFechaHora">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutFecha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6.dp"
                android:hint="Fecha">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFechaPaseo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutHora"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6.dp"
                android:hint="Hora">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHoraPaseo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <TextView
            android:id="@+id/lblInfoTarifa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.dp"
            android:text="La tarifa base del servicio es de S/ 10.00 por cada media hora."
            android:textColor="@android:color/darker_gray"
            android:textSize="13sp"
            android:textStyle="italic"
            app:layout_constraintTop_toBottomOf="@id/layoutFechaHoraInputs"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/lblTiempo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.dp"
            android:text="Duración del paseo"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/lblInfoTarifa"
            app:layout_constraintStart_toStartOf="parent" />

        <Spinner
            android:id="@+id/spinnerTiempo"
            android:layout_width="match_parent"
            android:layout_height="48.dp"
            android:layout_marginTop="6.dp"
            android:background="@android:drawable/btn_dropdown"
            app:layout_constraintTop_toBottomOf="@id/lblTiempo" />

        <TextView
            android:id="@+id/lblPrecioCalculado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.dp"
            android:background="#104CAF50"
            android:padding="12.dp"
            android:text="El precio estimado por el paseo es: S/ 0.00"
            android:textColor="#2E7D32"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/spinnerTiempo" />

        <TextView
            android:id="@+id/lblPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.dp"
            android:text="Método de Pago"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/lblPrecioCalculado"
            app:layout_constraintStart_toStartOf="parent" />

        <RadioGroup
            android:id="@+id/rgTipoPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6.dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/lblPago">

            <RadioButton
                android:id="@+id/rbEfectivo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:text="Efectivo" />

            <RadioButton
                android:id="@+id/rbYape"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Yape" />

            <RadioButton
                android:id="@+id/rbPlin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Plin" />
        </RadioGroup>

        <TextView
            android:id="@+id/lblDistritoPaseo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.dp"
            android:text="Distrito de Lima:"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/rgTipoPago"
            app:layout_constraintStart_toStartOf="parent" />

        <Spinner
            android:id="@+id/spinnerDistritos"
            android:layout_width="match_parent"
            android:layout_height="48.dp"
            android:layout_marginTop="6.dp"
            android:background="@android:drawable/btn_dropdown"
            app:layout_constraintTop_toBottomOf="@id/lblDistritoPaseo" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDireccionDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.dp"
            android:hint="Dirección exacta (Ej: Jr. Hatuncolla 164, Dpto 304)"
            app:layout_constraintTop_toBottomOf="@id/spinnerDistritos"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDireccionDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPostalAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/lblMapa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20.dp"
            android:text="Punto de recojo y zona permitida (Radio de seguridad)"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/layoutDireccionDetalle"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layoutRadioControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6.dp"
            app:layout_constraintTop_toBottomOf="@id/lblMapa"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/lblRadioMetros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Radio: 300m "
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:textSize="14sp"/>

            <SeekBar
                android:id="@+id/seekBarRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="4000"
                android:progress="300" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardMap"
            android:layout_width="match_parent"
            android:layout_height="280.dp"
            android:layout_marginTop="10.dp"
            app:cardCornerRadius="12.dp"
            app:cardElevation="2.dp"
            app:layout_constraintTop_toBottomOf="@id/layoutRadioControl"
            app:layout_constraintStart_toStartOf="parent">

            <fragment
                android:id="@+id/map"
                android:name="com.google.android.gms.maps.SupportMapFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.cardview.widget.CardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNotas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.dp"
            android:hint="Notas o preferencias para el paseo (opcional)"
            app:layout_constraintTop_toBottomOf="@id/cardMap"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSolicitarPaseo"
            android:layout_width="match_parent"
            android:layout_height="55.dp"
            android:layout_marginTop="24.dp"
            android:layout_marginBottom="16.dp"
            android:text="Confirmar Paseo"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/layoutNotas"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>